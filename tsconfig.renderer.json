{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src/renderer",
    "outDir": "./dist/renderer"
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
